{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EnterpriseRAG;Uid=root;Pwd=123456;Port=3306;Allow User Variables=True;"
  },
  "LlmOptions": {
    "DefaultModel": "ollama",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "ModelName": "qwen2.5:7b",
      "EmbeddingModelName": "nomic-embed-text:latest" // 向量模型

    },
    "Tongyi": {
      "ApiKey": "",
      "ModelName": "qwen-turbo"
    }
  },
  "VectorStoreOptions": {
    "DefaultType": "Qdrant",
    "Chroma": {
      "BaseUrl": "http://localhost:8000",
      "Timeout": 30,
      "Tenant": "default_tenant",
      "Database": "default_database",
      "CollectionName": "enterprise_rag_collection", //一个模型就是一个集合（不同的模型语义不同），一个权限就是一个集合，一类型的就是一个集合，根据业务区分
      "RetryCount": 2,
      "RetryDelayMilliseconds": 1000
    },
    "Qdrant": {
      "BaseUrl": "http://localhost:6333",
      "Timeout": 30,
      "CollectionName": "enterprise_rag_collection",
      "VectorSize": 1536,
      "DistanceMetric": "Cosine",
      "RetryCount": 2,
      "RetryDelayMilliseconds": 1000
    },
    "Unstructured": {
      "ApiUrl": "http://localhost:9000",
      "ApiKey": "your_secure_api_key_here"
    }
  }
}
